# Server
MYNA_HOST=0.0.0.0
MYNA_PORT=8000
MYNA_LOG_LEVEL=INFO
MYNA_ENV=development

# MCP
MYNA_MCP_SERVER_NAME=myna
MYNA_MCP_MOUNT_PATH=/mcp

# Admin API auth (set in non-dev environments)
MYNA_ADMIN_API_KEY=

# MCP endpoint auth. JSON object mapping bearer token -> caller label.
# In dev, leave empty to allow anonymous access. In staging/production,
# at least one key must be set or all /mcp traffic is rejected.
# Example:  MYNA_MCP_API_KEYS='{"sk-abc":"client-a","sk-def":"client-b"}'
MYNA_MCP_API_KEYS={}

# Per-caller rate limit on /mcp. Token-bucket: sustained rate of N
# requests per minute, burst capacity = N. Set to 0 to disable.
# Keyed by caller label when authenticated, else by client IP.
MYNA_MCP_RATE_LIMIT_PER_MINUTE=120

# OpenTelemetry tracing. Off by default — flip on to emit spans for
# HTTP requests and MCP tool calls. Without an exporter endpoint,
# spans go to stdout (handy for local development).
MYNA_OTEL_ENABLED=false
MYNA_OTEL_SERVICE_NAME=myna
# MYNA_OTEL_EXPORTER_ENDPOINT=http://otel-collector:4318/v1/traces
