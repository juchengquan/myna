# Server
MYNA_HOST=0.0.0.0
MYNA_PORT=8000
MYNA_LOG_LEVEL=INFO
MYNA_ENV=development

# MCP
MYNA_MCP_SERVER_NAME=myna
MYNA_MCP_MOUNT_PATH=/mcp

# Admin API auth (set in non-dev environments)
MYNA_ADMIN_API_KEY=

# MCP endpoint auth. JSON object mapping bearer token -> caller label.
# In dev, leave empty to allow anonymous access. In staging/production,
# at least one key must be set or all /mcp traffic is rejected.
# Example:  MYNA_MCP_API_KEYS='{"sk-abc":"client-a","sk-def":"client-b"}'
MYNA_MCP_API_KEYS={}
